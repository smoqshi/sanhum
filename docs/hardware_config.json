{
  "hardware": {
    "mode": "hybrid",
    "gpio": {
      "enabled": true,
      "motor_pins": {
        "left_motor": {
          "pwm_pin": 12,
          "dir_pin1": 5,
          "dir_pin2": 6,
          "enable_pin": 13
        },
        "right_motor": {
          "pwm_pin": 19,
          "dir_pin1": 20,
          "dir_pin2": 21,
          "enable_pin": 26
        }
      },
      "pwm_frequency": 1000,
      "max_duty_cycle": 100
    },
    "serial": {
      "esp32": {
        "port": null,
        "baudrate": 115200,
        "timeout": 1.0,
        "auto_detect": true
      },
      "arduino": {
        "port": null,
        "baudrate": 9600,
        "timeout": 1.0,
        "auto_detect": true
      }
    },
    "cameras": {
      "cameras": {
        "left": {
          "index": 0,
          "name": "Stereo Left",
          "resolution": [640, 480],
          "fps": 30,
          "auto_exposure": true,
          "auto_white_balance": true
        },
        "right": {
          "index": 1,
          "name": "Stereo Right", 
          "resolution": [640, 480],
          "fps": 30,
          "auto_exposure": true,
          "auto_white_balance": true
        },
        "mono": {
          "index": 2,
          "name": "Monocular",
          "resolution": [640, 480],
          "fps": 30,
          "auto_exposure": true,
          "auto_white_balance": true
        }
      },
      "stereo_baseline": 0.12,
      "auto_exposure": true,
      "auto_white_balance": true
    },
    "ros2": {
      "enabled": true,
      "node_name": "sanhum_robot",
      "namespace": "sanhum",
      "topics": {
        "cmd_vel": "/sanhum/cmd_vel",
        "odom": "/sanhum/odom",
        "joint_states": "/sanhum/joint_states",
        "sensors": {
          "ultrasonic_front": "/sanhum/sensors/ultrasonic_front",
          "ultrasonic_left": "/sanhum/sensors/ultrasonic_left",
          "ultrasonic_right": "/sanhum/sensors/ultrasonic_right",
          "ir_front_left": "/sanhum/sensors/ir_front_left",
          "ir_front_right": "/sanhum/sensors/ir_front_right",
          "ir_rear": "/sanhum/sensors/ir_rear"
        },
        "cameras": {
          "left": "/sanhum/camera/left/image_raw",
          "right": "/sanhum/camera/right/image_raw",
          "mono": "/sanhum/camera/mono/image_raw"
        }
      },
      "parameters": {
        "track_gauge": 0.35,
        "wheel_radius": 0.04,
        "max_linear_vel": 2.0,
        "max_angular_vel": 3.14,
        "update_rate": 20
      }
    },
    "robot_parameters": {
      "chassis_length": 0.6,
      "chassis_width": 0.5,
      "chassis_height": 0.3,
      "track_gauge": 0.35,
      "wheel_diameter": 0.08,
      "wheel_radius": 0.04,
      "manipulator": {
        "link1_length": 0.15,
        "link2_length": 0.13,
        "link3_length": 0.12,
        "link4_length": 0.10,
        "link5_length": 0.08,
        "gripper_width": 0.08,
        "joint_limits": [
          [-180, 180],
          [-90, 90],
          [-90, 90],
          [-90, 90],
          [-90, 90]
        ],
        "joint_speed_limits": [30, 20, 20, 20, 30]
      }
    },
    "safety": {
      "emergency_stop_enabled": true,
      "watchdog_timeout": 1.0,
      "max_motor_current": 5.0,
      "temperature_limit": 60.0,
      "voltage_limits": [10.0, 14.0]
    },
    "diagnostics": {
      "telemetry_rate": 10,
      "log_level": "INFO",
      "save_logs": true,
      "log_directory": "logs",
      "performance_monitoring": true
    }
  },
  "gui": {
    "theme": "dark",
    "window_size": [1600, 1000],
    "update_rate": 20,
    "show_debug_info": false,
    "enable_keyboard_control": true,
    "enable_gamepad_control": true,
    "camera_display": {
      "show_all_cameras": true,
      "default_camera": "mono",
      "camera_overlay": true
    },
    "manipulator_control": {
      "joint_speed": 2.0,
      "gripper_speed": 5.0,
      "show_joint_angles": true,
      "show_workspace": true
    }
  },
  "development": {
    "debug_mode": false,
    "simulation_mode": true,
    "hardware_simulation": true,
    "log_all_commands": false,
    "performance_profiling": false
  }
}
